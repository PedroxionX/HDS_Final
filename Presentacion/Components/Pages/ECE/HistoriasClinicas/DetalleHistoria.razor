@page "/detalles-historia/{Id:int}"
@using Aplicacion.DTOs.HistoriasClinicas
@inject Aplicacion.Servicios.Interfaces.IHistoriaClinicaService HistoriaService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Detalles de Historia Clinica</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-info text-white text-center rounded-top-4">
                    <h4 class="mb-0">
                        <i class="fas fa-notes-medical me-2"></i>Detalles de la Historia Clinica
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(MensajeError))
                    {
                        <div class="alert alert-danger text-center">
                            <i class="fas fa-exclamation-triangle me-2"></i>@MensajeError
                        </div>
                    }
                    else if (Cargando || Historia == null)
                    {
                        <div class="alert alert-warning text-center">
                            <i class="fas fa-spinner fa-pulse me-2"></i>Cargando información...
                        </div>
                    }
                    else
                    {
                        <div class="row mb-4">
                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-hashtag me-1"></i> ID Historia
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Historia.Id</p>
                            </div>
                            <div class="col-md-9 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-user me-1"></i> Paciente
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Historia.NombrePaciente</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-calendar-alt me-1"></i> Fecha Apertura
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Historia.FechaApertura.ToString("dd/MM/yyyy")</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-flag me-1"></i> Estado
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@(Historia.Activo ? "Activo" : "Inactivo")</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-muted">Alergias</label>
                                <p class="form-control-plaintext fw-bold bg-light">@MostrarTexto(Historia.Alergias)</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-muted">Antecedentes Familiares</label>
                                <p class="form-control-plaintext fw-bold bg-light">@MostrarTexto(Historia.AntecedentesFamiliares)</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-muted">Antecedentes Personales</label>
                                <p class="form-control-plaintext fw-bold bg-light">@MostrarTexto(Historia.AntecedentesPersonales)</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">Creación</label>
                                <p class="form-control-plaintext fw-bold bg-light">@Historia.FechaDeCreacion.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">Modificación</label>
                                <p class="form-control-plaintext fw-bold bg-light">@(Historia.FechaDeModificacion.HasValue ? Historia.FechaDeModificacion.Value.ToString("dd/MM/yyyy HH:mm") : "—")</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">Eliminación</label>
                                <p class="form-control-plaintext fw-bold bg-light">@(Historia.FechaDeEliminacion.HasValue ? Historia.FechaDeEliminacion.Value.ToString("dd/MM/yyyy HH:mm") : "—")</p>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="button" class="btn btn-secondary px-4" @onclick="VolverAlListado">
                                <i class="fas fa-arrow-left me-1"></i> Volver al listado
                            </button>
                            <button type="button" class="btn btn-info px-4" @onclick="() => VerEvoluciones(Historia.Id)">
                                <i class="fas fa-chart-line me-1"></i> Ver evoluciones
                            </button>
                            <button type="button" class="btn btn-primary px-4" @onclick="() => EditarHistoria(Historia.Id)">
                                <i class="fas fa-edit me-1"></i> Editar historia
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

