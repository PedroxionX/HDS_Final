@page "/crear-historia"
@using Aplicacion.DTOs.HistoriasClinicas
@inject Aplicacion.Servicios.Interfaces.IHistoriaClinicaService HistoriaService
@inject Aplicacion.Servicios.Interfaces.IPacienteService PacienteService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Crear Historia Clinica</PageTitle>

<div class="container mt-4">
<div class="row justify-content-center">
<div class="col-lg-8 col-md-10 col-sm-12">
<div class="card shadow-lg border-0 rounded-4">
<div class="card-header bg-success bg-gradient text-white">
    <h5 class="mb-0">
        <i class="fas fa-notes-medical me-2"></i>Crear Nueva Historia Clinica
    </h5>
</div>
<div class="card-body p-4">
@if (!string.IsNullOrEmpty(MensajeError))
{
    <div class="alert alert-danger">@MensajeError</div>
}
@if (Cargando)
{
    <div class="text-center py-5">
        <i class="fas fa-spinner fa-pulse fa-2x text-primary"></i>
        <p class="mt-2">Cargando datos...</p>
    </div>
}
else if (Pacientes == null || !Pacientes.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle me-2"></i> No hay pacientes disponibles sin historia clínica activa.
    </div>
    <div class="d-flex justify-content-end gap-2 mt-3">
        <button type="button" class="btn btn-secondary px-4" @onclick="Cancelar">
            <i class="fas fa-times me-1"></i> Cancelar
        </button>
    </div>
}
else
{
    <EditForm Model="@historiaDTO" OnValidSubmit="GrabarHistoria">
        <FluentValidator />
        <ValidationSummary class="text-danger mb-3" />
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-user me-1"></i> Paciente
                </label>
                <InputSelect class="form-select" @bind-Value="historiaDTO.IdPaciente">
                    <option value="0">-- Seleccione un paciente --</option>
                    @if (Pacientes != null)
                    {
                        @foreach (var paciente in Pacientes)
                        {
                            <option value="@paciente.Id">@paciente.Nombres @paciente.Apellidos</option>
                        }
                    }
                </InputSelect>
                <ValidationMessage For="@(() => historiaDTO.IdPaciente)" class="text-danger small" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-calendar-alt me-1"></i> Fecha Apertura
                </label>
                <InputDate class="form-control" @bind-Value="historiaDTO.FechaApertura" />
                <ValidationMessage For="@(() => historiaDTO.FechaApertura)" class="text-danger small" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Alergias (opcional)</label>
            <InputTextArea class="form-control" @bind-Value="historiaDTO.Alergias" rows="3" />
            <small class="text-muted">@(historiaDTO.Alergias?.Length ?? 0) / 500 caracteres</small>
            <ValidationMessage For="@(() => historiaDTO.Alergias)" class="text-danger small" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Antecedentes Familiares (opcional)</label>
            <InputTextArea class="form-control" @bind-Value="historiaDTO.AntecedentesFamiliares" rows="3" />
            <small class="text-muted">@(historiaDTO.AntecedentesFamiliares?.Length ?? 0) / 500 caracteres</small>
            <ValidationMessage For="@(() => historiaDTO.AntecedentesFamiliares)" class="text-danger small" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Antecedentes Personales (opcional)</label>
            <InputTextArea class="form-control" @bind-Value="historiaDTO.AntecedentesPersonales" rows="3" />
            <small class="text-muted">@(historiaDTO.AntecedentesPersonales?.Length ?? 0) / 500 caracteres</small>
            <ValidationMessage For="@(() => historiaDTO.AntecedentesPersonales)" class="text-danger small" />
        </div>
        <div class="mb-3 form-check">
            <InputCheckbox class="form-check-input" @bind-Value="historiaDTO.Activo" />
            <label class="form-check-label">Activo</label>
        </div>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button type="button" class="btn btn-secondary px-4" @onclick="Cancelar">
                <i class="fas fa-times me-1"></i> Cancelar
            </button>
            <button type="submit" class="btn btn-success px-4">
                <i class="fas fa-save me-1"></i> Guardar Historia
            </button>
        </div>
    </EditForm>
}
</div>
</div>
</div>
</div>
</div>

