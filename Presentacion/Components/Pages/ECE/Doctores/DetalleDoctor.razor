@page "/detalles-doctor/{id:int}"
@using Aplicacion.DTOs.Doctores
@using Aplicacion.Helpers
@inject Aplicacion.Servicios.Interfaces.IDoctorServicio DoctorServicio
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
<PageTitle>Detalles del Doctor</PageTitle>
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-info text-white text-center rounded-top-4">
                    <h4 class="mb-0">
                        <i class="fas fa-user-md me-2"></i>Detalles del Doctor
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(MensajeError))
                    {
                        <div class="alert alert-danger text-center">
                            <i class="fas fa-exclamation-triangle me-2"></i>@MensajeError
                        </div>
                    }
                    else if (Cargando || Doctor == null)
                    {
                        <div class="alert alert-warning text-center">
                            <i class="fas fa-spinner fa-pulse me-2"></i>Cargando información...
                        </div>
                    }
                    else
                    {
                        <div class="row mb-4">
                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-hashtag me-1"></i> ID Doctor
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Doctor.Id</p>
                            </div>
                            <div class="col-md-5 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-user me-1"></i> Nombre Complet
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Doctor.Nombre</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-stethoscope me-1"></i> Especialidad
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Doctor.NombreEspecialidad</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-phone me-1"></i> Teléfono
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@(string.IsNullOrEmpty(Doctor.Telefono) ? "—" : Doctor.Telefono)</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-envelope me-1"></i> Email
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@(string.IsNullOrEmpty(Doctor.Email) ? "—" : Doctor.Email)</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-calendar-alt me-1"></i> F. Contratación
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Doctor.FechaContratacion.ToShortDateString()</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-align-left me-1"></i> Descripción
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@(string.IsNullOrEmpty(Doctor.Descripcion) ? "—" : Doctor.Descripcion)</p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-info-circle me-1"></i> Estado
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">
                                    @if (Doctor.Activo)
                                    {
                                        <i class="fas fa-check-circle text-success fs-5 me-1"></i>
                                        <span class="text-success">Activo</span>
                                    }
                                    else
                                    {
                                        <i class="fas fa-times-circle text-danger fs-5 me-1"></i>
                                        <span class="text-danger">Inactivo</span>
                                    }
                                </p>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="button" class="btn btn-secondary px-4" @onclick="VolverAlListado">
                                <i class="fas fa-arrow-left me-1"></i> Volver al listado
                            </button>
                            <button type="button" class="btn btn-primary px-4" @onclick="() => EditarDoctor(Doctor.Id)">
                                <i class="fas fa-edit me-1"></i> Editar doctor
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
