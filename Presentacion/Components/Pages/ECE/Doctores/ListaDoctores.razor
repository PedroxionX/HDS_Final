@page "/doctores"
@inject Aplicacion.Servicios.Interfaces.IDoctorServicio DoctorServicio
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
<PageTitle>Lista de Doctores</PageTitle>
<div class="container mt-4">
<div class="card shadow-lg border-0 rounded-4">
<div class="card-header bg-primary text-white rounded-top-4">
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="mb-0">
            <i class="fas fa-user-md me-2"></i>Listado de Doctores
        </h4>
        <button class="btn btn-success" @onclick="IrACrearNuevo">
            <i class="fas fa-plus-circle me-1"></i> Nuevo Doctor
        </button>
    </div>
</div>
<div class="card-body p-2 bg-primary-subtle">
@if (Cargando)
{
    <div class="text-center py-5">
        <i class="fas fa-spinner fa-pulse fa-2x text-primary"></i>
        <p class="mt-2">Cargando doctores...</p>
    </div>
}
else if (!string.IsNullOrEmpty(MensajeError))
{
    <div class="alert alert-danger">@MensajeError</div>
}
else if (Doctores == null || !Doctores.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle me-2"></i> No hay doctores registrados.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Especialidad</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doctor in Doctores)
                {
                    <tr>
                        <td>@doctor.Nombre</td>
                        <td>@doctor.NombreEspecialidad</td>
                        <td>@doctor.Telefono</td>
                        <td>@doctor.Email</td>
                        <td>
                            @if (doctor.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info me-1" @onclick="() => VerDetalles(doctor.Id)" title="Detalles">
                                <i class="fas fa-eye"></i>
                            </button>
                            <button class="btn btn-sm btn-warning me-1" @onclick="() => EditarDoctor(doctor.Id)" title="Editar">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmarEliminar(doctor.Id, doctor.Nombre)" title="Eliminar">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
</div>
</div>
</div>
