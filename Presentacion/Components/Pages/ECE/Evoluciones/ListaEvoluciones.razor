@page "/evoluciones"
@page "/evoluciones/{IdHistoria:int}"
@using Aplicacion.DTOs.Evoluciones
@inject Aplicacion.Servicios.Interfaces.IEvolucionService EvolucionService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Lista de Evoluciones</PageTitle>

<div class="container mt-4">
<div class="card shadow-lg border-0 rounded-4">
<div class="card-header bg-primary text-white rounded-top-4">
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="mb-0">
            <i class="fas fa-chart-line me-2"></i>Listado de Evoluciones
        </h4>
        <button class="btn btn-success" @onclick="IrACrear">
            <i class="fas fa-plus-circle me-1"></i> Nueva Evolucion
        </button>
    </div>
</div>
<div class="card-body p-2 bg-primary-subtle">
@if (Cargando)
{
    <div class="text-center py-5">
        <i class="fas fa-spinner fa-pulse fa-2x text-primary"></i>
        <p class="mt-2">Cargando evoluciones...</p>
    </div>
}
else if (!string.IsNullOrEmpty(MensajeError))
{
    <div class="alert alert-danger">@MensajeError</div>
}
else if (Evoluciones == null || !Evoluciones.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle me-2"></i> No hay evoluciones registradas.
    </div>
}
else
{
    @if (ResumenPacientes.Any())
    {
        <div class="card mb-3 border-0 shadow-sm">
            <div class="card-body">
                <h6 class="mb-2"><i class="fas fa-user-friends me-2"></i>Resumen por paciente</h6>
                <div class="row">
                    @foreach (var item in ResumenPacientes)
                    {
                        <div class="col-md-4 col-sm-6 mb-2">
                            <span class="badge bg-secondary me-1">@item.Cantidad</span>@item.NombrePaciente
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Paciente</th>
                    <th>Doctor</th>
                    <th>Fecha</th>
                    <th>Diagnostico</th>
                    <th>Tratamiento</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evolucion in Evoluciones)
                {
                    <tr>
                        <td>@evolucion.NombrePaciente</td>
                        <td>@evolucion.NombreDoctor (@evolucion.NombreEspecialidad)</td>
                        <td>@evolucion.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@ObtenerTextoCorto(evolucion.Diagnostico, 40)</td>
                        <td>@ObtenerTextoCorto(evolucion.Tratamiento, 40)</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info me-1" @onclick="() => VerDetalles(evolucion.Id)" title="Detalles">
                                <i class="fas fa-eye"></i>
                            </button>
                            <button class="btn btn-sm btn-warning me-1" @onclick="() => Editar(evolucion.Id)" title="Editar">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmarEliminar(evolucion.Id, evolucion.NombrePaciente)" title="Eliminar">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
</div>
</div>
</div>

