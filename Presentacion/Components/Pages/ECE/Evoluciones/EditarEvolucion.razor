@page "/editar-evolucion/{Id:int}"
@using Aplicacion.DTOs.Evoluciones
@inject Aplicacion.Servicios.Interfaces.IEvolucionService EvolucionService
@inject Aplicacion.Servicios.Interfaces.IHistoriaClinicaService HistoriaClinicaService
@inject Aplicacion.Servicios.Interfaces.IDoctorServicio DoctorServicio
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Editar Evolucion</PageTitle>

<div class="container mt-4">
<div class="row justify-content-center">
<div class="col-lg-8 col-md-10 col-sm-12">
<div class="card shadow-lg border-0 rounded-4">
<div class="card-header bg-warning bg-gradient text-dark">
    <h5 class="mb-0">
        <i class="fas fa-notes-medical me-2"></i>Editar Evolucion
    </h5>
</div>
<div class="card-body p-4">
@if (!string.IsNullOrEmpty(MensajeError))
{
    <div class="alert alert-danger">@MensajeError</div>
}
@if (Cargando)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-2">Cargando datos...</p>
    </div>
}
else if (evolucionDTO != null)
{
    <EditForm Model="@evolucionDTO" OnValidSubmit="GrabarEvolucion">
        <FluentValidator />
        <ValidationSummary class="text-danger mb-3" />
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-file-medical me-1"></i> Historia Clinica
                </label>
                <InputSelect class="form-select" @bind-Value="evolucionDTO.IdHistoriaClinica" disabled>
                    @if (Historias != null)
                    {
                        @foreach (var historia in Historias)
                        {
                            <option value="@historia.Id">@historia.NombrePaciente</option>
                        }
                    }
                </InputSelect>
                <ValidationMessage For="@(() => evolucionDTO.IdHistoriaClinica)" class="text-danger small" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-user-md me-1"></i> Doctor
                </label>
                <InputSelect class="form-select" @bind-Value="evolucionDTO.IdDoctor" disabled>
                    @if (Doctores != null)
                    {
                        @foreach (var doctor in Doctores)
                        {
                            <option value="@doctor.Id">@doctor.Nombre (@doctor.NombreEspecialidad)</option>
                        }
                    }
                </InputSelect>
                <ValidationMessage For="@(() => evolucionDTO.IdDoctor)" class="text-danger small" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-calendar-alt me-1"></i> Fecha
                </label>
                <InputDate class="form-control" @bind-Value="evolucionDTO.Fecha" disabled />
                <ValidationMessage For="@(() => evolucionDTO.Fecha)" class="text-danger small" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-check-circle me-1"></i> Activo
                </label>
                <div class="form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="evolucionDTO.Activo" />
                    <label class="form-check-label">Registro activo</label>
                </div>
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">
                <i class="fas fa-stethoscope me-1"></i> Diagnostico
            </label>
            <InputTextArea class="form-control" @bind-Value="evolucionDTO.Diagnostico" rows="3" />
            <div class="d-flex justify-content-between">
                <ValidationMessage For="@(() => evolucionDTO.Diagnostico)" class="text-danger small" />
                <small class="text-muted">@Contador(evolucionDTO.Diagnostico, 500)</small>
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">
                <i class="fas fa-prescription-bottle-alt me-1"></i> Tratamiento
            </label>
            <InputTextArea class="form-control" @bind-Value="evolucionDTO.Tratamiento" rows="3" />
            <div class="d-flex justify-content-between">
                <ValidationMessage For="@(() => evolucionDTO.Tratamiento)" class="text-danger small" />
                <small class="text-muted">@Contador(evolucionDTO.Tratamiento, 500)</small>
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">
                <i class="fas fa-sticky-note me-1"></i> Notas (opcional)
            </label>
            <InputTextArea class="form-control" @bind-Value="evolucionDTO.Notas" rows="3" />
            <div class="d-flex justify-content-between">
                <ValidationMessage For="@(() => evolucionDTO.Notas)" class="text-danger small" />
                <small class="text-muted">@Contador(evolucionDTO.Notas, 1000)</small>
            </div>
        </div>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button type="button" class="btn btn-secondary px-4" @onclick="Cancelar">
                <i class="fas fa-times me-1"></i> Cancelar
            </button>
            <button type="submit" class="btn btn-success px-4">
                <i class="fas fa-save me-1"></i> Actualizar Evolucion
            </button>
        </div>
    </EditForm>
}
</div>
</div>
</div>
</div>
</div>

