@page "/detalles-evolucion/{Id:int}"
@using Aplicacion.DTOs.Evoluciones
@inject Aplicacion.Servicios.Interfaces.IEvolucionService EvolucionService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Detalles de Evolucion</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-info text-white text-center rounded-top-4">
                    <h4 class="mb-0">
                        <i class="fas fa-notes-medical me-2"></i>Detalles de la Evolucion
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(MensajeError))
                    {
                        <div class="alert alert-danger text-center">
                            <i class="fas fa-exclamation-triangle me-2"></i>@MensajeError
                        </div>
                    }
                    else if (Cargando || Evolucion == null)
                    {
                        <div class="alert alert-warning text-center">
                            <i class="fas fa-spinner fa-pulse me-2"></i>Cargando informacion...
                        </div>
                    }
                    else
                    {
                        <div class="row mb-4">
                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-hashtag me-1"></i> ID Evolucion
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Evolucion.Id</p>
                            </div>
                            <div class="col-md-5 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-user me-1"></i> Paciente
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Evolucion.NombrePaciente</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-user-md me-1"></i> Doctor
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Evolucion.NombreDoctor (@Evolucion.NombreEspecialidad)</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-calendar-alt me-1"></i> Fecha
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Evolucion.Fecha.ToString("dd/MM/yyyy")</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-flag me-1"></i> Estado
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@(Evolucion.Activo ? "Activo" : "Inactivo")</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-stethoscope me-1"></i> Diagnostico
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Evolucion.Diagnostico</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-prescription-bottle-alt me-1"></i> Tratamiento
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Evolucion.Tratamiento</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-sticky-note me-1"></i> Notas
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@MostrarTexto(Evolucion.Notas)</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">Creacion</label>
                                <p class="form-control-plaintext fw-bold bg-light">@Evolucion.FechaDeCreacion.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">Modificacion</label>
                                <p class="form-control-plaintext fw-bold bg-light">@(Evolucion.FechaDeModificacion.HasValue ? Evolucion.FechaDeModificacion.Value.ToString("dd/MM/yyyy HH:mm") : "—")</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">Eliminacion</label>
                                <p class="form-control-plaintext fw-bold bg-light">@(Evolucion.FechaDeEliminacion.HasValue ? Evolucion.FechaDeEliminacion.Value.ToString("dd/MM/yyyy HH:mm") : "—")</p>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="button" class="btn btn-secondary px-4" @onclick="VolverAlListado">
                                <i class="fas fa-arrow-left me-1"></i> Volver al listado
                            </button>
                            <button type="button" class="btn btn-primary px-4" @onclick="() => EditarEvolucion(Evolucion.Id)">
                                <i class="fas fa-edit me-1"></i> Editar evolucion
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

