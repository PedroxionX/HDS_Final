@page "/detalles-cita/{Id:int}"
@using Aplicacion.DTOs.Citas
@inject Aplicacion.Servicios.Interfaces.ICitaService CitaService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Detalles de Cita</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-info text-white text-center rounded-top-4">
                    <h4 class="mb-0">
                        <i class="fas fa-calendar-check me-2"></i>Detalles de la Cita
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(MensajeError))
                    {
                        <div class="alert alert-danger text-center">
                            <i class="fas fa-exclamation-triangle me-2"></i>@MensajeError
                        </div>
                    }
                    else if (Cargando || Cita == null)
                    {
                        <div class="alert alert-warning text-center">
                            <i class="fas fa-spinner fa-pulse me-2"></i>Cargando información...
                        </div>
                    }
                    else
                    {
                        <div class="row mb-4">
                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-hashtag me-1"></i> ID Cita
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Cita.Id</p>
                            </div>
                            <div class="col-md-5 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-user me-1"></i> Paciente
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Cita.NombrePaciente</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-user-md me-1"></i> Doctor
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Cita.NombreDoctor</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-calendar-alt me-1"></i> Fecha y Hora
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Cita.FechaHora.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-flag me-1"></i> Estado
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@ObtenerTextoEstado(Cita.Estado)</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-comment-dots me-1"></i> Motivo
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@Cita.Motivo</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-muted">
                                    <i class="fas fa-notes-medical me-1"></i> Notas
                                </label>
                                <p class="form-control-plaintext fw-bold bg-light">@(string.IsNullOrEmpty(Cita.Notas) ? "—" : Cita.Notas)</p>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">Creación</label>
                                <p class="form-control-plaintext fw-bold bg-light">@Cita.FechaDeCreacion.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">Modificación</label>
                                <p class="form-control-plaintext fw-bold bg-light">@(Cita.FechaDeModificacion.HasValue ? Cita.FechaDeModificacion.Value.ToString("dd/MM/yyyy HH:mm") : "—")</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold text-muted">Eliminación</label>
                                <p class="form-control-plaintext fw-bold bg-light">@(Cita.FechaDeEliminacion.HasValue ? Cita.FechaDeEliminacion.Value.ToString("dd/MM/yyyy HH:mm") : "—")</p>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="button" class="btn btn-secondary px-4" @onclick="VolverAlListado">
                                <i class="fas fa-arrow-left me-1"></i> Volver al listado
                            </button>
                            <button type="button" class="btn btn-primary px-4" @onclick="() => EditarCita(Cita.Id)">
                                <i class="fas fa-edit me-1"></i> Editar cita
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

