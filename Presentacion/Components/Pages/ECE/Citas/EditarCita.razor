@page "/editar-cita/{Id:int}"
@using Aplicacion.DTOs.Citas
@inject Aplicacion.Servicios.Interfaces.ICitaService CitaService
@inject Aplicacion.Servicios.Interfaces.IPacienteService PacienteService
@inject Aplicacion.Servicios.Interfaces.IDoctorServicio DoctorServicio
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Editar Cita</PageTitle>

<div class="container mt-4">
<div class="row justify-content-center">
<div class="col-lg-8 col-md-10 col-sm-12">
<div class="card shadow-lg border-0 rounded-4">
<div class="card-header bg-warning bg-gradient text-dark">
    <h5 class="mb-0">
        <i class="fas fa-calendar-edit me-2"></i>Editar Cita
    </h5>
</div>
<div class="card-body p-4">
@if (!string.IsNullOrEmpty(MensajeError))
{
    <div class="alert alert-danger">@MensajeError</div>
}
@if (Cargando)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-2">Cargando datos...</p>
    </div>
}
else if (citaDTO != null)
{
    <EditForm Model="@citaDTO" OnValidSubmit="GrabarCita">
        <FluentValidator />
        <ValidationSummary class="text-danger mb-3" />
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-user me-1"></i> Paciente
                </label>
                <InputSelect class="form-select" @bind-Value="citaDTO.IdPaciente">
                    <option value="0">-- Seleccione un paciente --</option>
                    @if (Pacientes != null)
                    {
                        @foreach (var paciente in Pacientes)
                        {
                            <option value="@paciente.Id">@paciente.Nombres @paciente.Apellidos</option>
                        }
                    }
                </InputSelect>
                <ValidationMessage For="@(() => citaDTO.IdPaciente)" class="text-danger small" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-user-md me-1"></i> Doctor
                </label>
                <InputSelect class="form-select" @bind-Value="citaDTO.IdDoctor">
                    <option value="0">-- Seleccione un doctor --</option>
                    @if (Doctores != null)
                    {
                        @foreach (var doctor in Doctores)
                        {
                            <option value="@doctor.Id">@doctor.Nombre</option>
                        }
                    }
                </InputSelect>
                <ValidationMessage For="@(() => citaDTO.IdDoctor)" class="text-danger small" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-calendar-alt me-1"></i> Fecha
                </label>
                <InputDate class="form-control" @bind-Value="FechaSeleccionada" />
                <ValidationMessage For="@(() => citaDTO.FechaHora)" class="text-danger small" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-clock me-1"></i> Hora
                </label>
                <input type="time" class="form-control" @bind="HoraSeleccionada" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">
                <i class="fas fa-comment-dots me-1"></i> Motivo
            </label>
            <InputTextArea class="form-control" @bind-Value="citaDTO.Motivo" rows="3" />
            <ValidationMessage For="@(() => citaDTO.Motivo)" class="text-danger small" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">
                <i class="fas fa-notes-medical me-1"></i> Notas (opcional)
            </label>
            <InputTextArea class="form-control" @bind-Value="citaDTO.Notas" rows="3" />
            <ValidationMessage For="@(() => citaDTO.Notas)" class="text-danger small" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">
                <i class="fas fa-flag me-1"></i> Estado
            </label>
            <InputSelect class="form-select" @bind-Value="citaDTO.Estado">
                @foreach (var estado in Estados)
                {
                    <option value="@estado.Value">@estado.Nombre</option>
                }
            </InputSelect>
        </div>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button type="button" class="btn btn-secondary px-4" @onclick="Cancelar">
                <i class="fas fa-times me-1"></i> Cancelar
            </button>
            <button type="submit" class="btn btn-success px-4">
                <i class="fas fa-save me-1"></i> Actualizar Cita
            </button>
        </div>
    </EditForm>
}
</div>
</div>
</div>
</div>
</div>
