@page "/citas"
@using Aplicacion.DTOs.Citas
@inject Aplicacion.Servicios.Interfaces.ICitaService CitaService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Lista de Citas</PageTitle>

<div class="container mt-4">
<div class="card shadow-lg border-0 rounded-4">
<div class="card-header bg-primary text-white rounded-top-4">
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="mb-0">
            <i class="fas fa-calendar-alt me-2"></i>Listado de Citas
        </h4>
        <button class="btn btn-success" @onclick="IrACrear">
            <i class="fas fa-plus-circle me-1"></i> Nueva Cita
        </button>
    </div>
</div>
<div class="card-body p-2 bg-primary-subtle">
@if (Cargando)
{
    <div class="text-center py-5">
        <i class="fas fa-spinner fa-pulse fa-2x text-primary"></i>
        <p class="mt-2">Cargando citas...</p>
    </div>
}
else if (!string.IsNullOrEmpty(MensajeError))
{
    <div class="alert alert-danger">@MensajeError</div>
}
else if (Citas == null || !Citas.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle me-2"></i> No hay citas registradas.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Paciente</th>
                    <th>Doctor</th>
                    <th>Fecha y Hora</th>
                    <th>Motivo</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cita in Citas)
                {
                    <tr>
                        <td>@cita.NombrePaciente</td>
                        <td>@cita.NombreDoctor</td>
                        <td>@cita.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@ObtenerMotivoCorto(cita.Motivo)</td>
                        <td>
                            <span class="badge @ObtenerClaseEstado(cita.Estado)">@ObtenerTextoEstado(cita.Estado)</span>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info me-1" @onclick="() => VerDetalles(cita.Id)" title="Detalles">
                                <i class="fas fa-eye"></i>
                            </button>
                            <button class="btn btn-sm btn-warning me-1" @onclick="() => Editar(cita.Id)" title="Editar">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmarEliminar(cita.Id, cita.NombrePaciente)" title="Eliminar">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
</div>
</div>
</div>

