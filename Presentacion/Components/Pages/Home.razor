@page "/"
<div class="container-fluid" style="background-image: url('/lib/imagenes/fondo.jpg'), linear-gradient(135deg, #667eea 0%, #764ba2 100%); background-size: cover; background-position: center; height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Panel de Control</h2>
        <div class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</div>
    </div>
    <div class="row g-4">
        <div class="col-md-6 col-lg-3">
            <div class="card-stats">
                <i class="fas fa-users icon-primary"></i>
                <h3>324</h3>
                <p>Pacientes Activos</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card-stats">
                <i class="fas fa-calendar-check icon-success"></i>
                <h3>18</h3>
                <p>Citas Hoy</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card-stats">
                <i class="fas fa-user-md icon-info"></i>
                <h3>12</h3>
                <p>Doctores</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card-stats">
                <i class="fas fa-chart-line icon-warning"></i>
                <h3>89%</h3>
                <p>Satisfacción</p>
            </div>
        </div>
    </div>
    <div class="row mt-5">
        <div class="col-lg-7">
            <div class="card-modern">
                <h5><i class="fas fa-calendar-week"></i> Próximas Citas</h5>
                <div class="table-responsive">
                    <table class="table table-modern">
                        <thead>
                        <tr>
                            <th>Paciente</th>
                            <th>Doctor</th>
                            <th>Hora</th>
                            <th>Estado</th>
                        </tr>
                        </thead>
                        <tbody>
                        <tr>
                            <td>Ana López</td>
                            <td>Dr. Martínez</td>
                            <td>10:00 AM</td>
                            <td><span class="badge bgsuccess">Confirmada</span></td>
                        </tr>
                        <tr>
                            <td>Carlos Ruiz</td>
                            <td>Dra. Gómez</td>
                            <td>11:30 AM</td>
                            <td><span class="badge bgwarning">Pendiente</span></td>
                        </tr>
                        <tr>
                            <td>María Paz</td>
                            <td>Dr. Fernández</td>
                            <td>12:15 PM</td>
                            <td><span class="badge bgsuccess">Confirmada</span></td>
                        </tr>
                        </tbody>
                    </table>
                </div>
                <a href="/citas" class="btn btn-sm btn-link">Ver todas →</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card-modern">
                <h5><i class="fas fa-chart-simple"></i> Evolución Reciente</h5>
                <div class="list-group list-group-flush">
                    <div class="list-group-item bg-transparent">Juan Pérez - Presión arterial controlada</div>
                    <div class="list-group-item bg-transparent">Luisa Gómez - Mejoría en diabetes tipo 2</div>
                    <div class="list-group-item bg-transparent">Pedro Ramírez - Cambio de medicación</div>
                </div>
            </div>
        </div>
    </div>
</div>