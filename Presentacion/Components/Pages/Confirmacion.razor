@page "/alerts"
@inject IJSRuntime JSRuntime
<button class="btn btn-primary" @onclick="MostrarConfirmacion">Mostrar Confirmación</button>
@code {
    private async Task MostrarConfirmacion()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("SweetAlert.showConfirm",
            "¿Estás seguro?", "Esta acción no se puede deshacer.", "warning", "Sí, eliminar");
        if (confirmed)
        {
            // Lógica para cuando el usuario confirma
            await JSRuntime.InvokeVoidAsync("Swal.fire", "Eliminado", "Tu archivo ha sido eliminado.", "success");
        }
        else
        {
            // Lógica para cuando el usuario cancela
            await JSRuntime.InvokeVoidAsync("Swal.fire", "Cancelado", "Tu archivo está a salvo :)", "error");
        }
    }
}